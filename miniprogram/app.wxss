/** app.wxss **/

/*
  CS Gaming Theme - 深色模式/浅色模式适配
  浅色模式（默认）：白底黑字
  深色模式（系统深色）：黑底白字
  猜一猜（guess）页面不参与此适配，始终保持原有风格
*/

/* ========== 1. CSS 变量定义（浅色模式 = 默认） ========== */
page {
  /* 主色 */
  --primary-color: #0066CC;
  --secondary-color: #FF9800;
  --success-color: #4CAF50;
  --error-color: #F44336;
  --accent-color: #0066CC;

  /* 背景色 */
  --bg-page: #FFFFFF;
  --bg-card: #F5F5F5;
  --bg-input: #EEEEEE;
  --bg-hover: #E0E0E0;
  --bg-page-secondary: #FAFAFA;

  /* 边框 */
  --border-color: #E0E0E0;
  --border-light: #EEEEEE;
  --border-input: #CCCCCC;

  /* 文字色 */
  --text-primary: #000000;
  --text-secondary: #666666;
  --text-muted: #999999;
  --text-inverse: #FFFFFF;

  /* 弹窗/遮罩 */
  --modal-backdrop: rgba(0, 0, 0, 0.5);
  --modal-bg: #FFFFFF;
  --modal-border: #E0E0E0;

  /* UI 组件 */
  --btn-primary-bg: #0066CC;
  --btn-primary-text: #FFFFFF;
  --btn-secondary-bg: #F0F0F0;
  --btn-secondary-text: #333333;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);

  /* Spacing */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  background-color: var(--bg-page);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* ========== 2. 深色模式覆盖 ========== */
@media (prefers-color-scheme: dark) {
  page {
    --primary-color: #00E5FF;
    --secondary-color: #FFC107;
    --success-color: #00C853;
    --error-color: #FF3D00;
    --accent-color: #00E5FF;

    --bg-page: #0F111A;
    --bg-card: #1E212B;
    --bg-input: #2C2F3E;
    --bg-hover: #3C3F4E;
    --bg-page-secondary: #16181F;

    --border-color: #3C3F4E;
    --border-light: #2C2F3E;
    --border-input: #3C3F4E;

    --text-primary: #FFFFFF;
    --text-secondary: #B0BEC5;
    --text-muted: #546E7A;
    --text-inverse: #000000;

    --modal-backdrop: rgba(0, 0, 0, 0.7);
    --modal-bg: #1E212B;
    --modal-border: #3C3F4E;

    --btn-primary-bg: #00E5FF;
    --btn-primary-text: #000000;
    --btn-secondary-bg: #2C2F3E;
    --btn-secondary-text: #B0BEC5;

    --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8rpx 30rpx rgba(0, 0, 0, 0.5);
  }
}

/* Flex Helper Classes */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.align-center {
  align-items: center;
}

/* Common Components */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: var(--spacing-md);
}

.card {
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.btn {
  background-color: var(--primary-color);
  color: #000;
  font-weight: bold;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: 8rpx;
  text-align: center;
  transition: opacity 0.2s;
}

.btn:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

/* Typography */
.h1 {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-md);
}

.h2 {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-sm);
}

.text-muted {
  color: var(--text-muted);
}
