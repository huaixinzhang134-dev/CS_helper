<view class="container events-page">
  <view class="header">
    <view class="h1">赛事中心</view>
    <text class="subtitle">按赛事分类浏览</text>
  </view>

  <!-- 等级筛选栏 -->
  <scroll-view scroll-x class="grade-filter" style="display:flex;flex-wrap:nowrap;padding:8rpx 16rpx;white-space:nowrap;">
    <view
      wx:for="{{gradeOptions}}"
      wx:key="value"
      class="grade-tab {{gradeFilter === item.value ? 'grade-tab-active' : ''}}"
      data-value="{{item.value === null ? 'null' : item.value}}"
      bindtap="onSelectGrade"
      style="display:inline-block;padding:6rpx 20rpx;margin:0 6rpx;border-radius:6rpx;font-size:26rpx;{{gradeFilter === item.value ? 'background:var(--primary-color);color:#fff;' : 'background:#f0f0f0;color:#333;'}}"
    >{{item.label}}</view>
  </scroll-view>

  <scroll-view scroll-y class="events-list" refresher-enabled="{{true}}" bindrefresherrefresh="onPullDownRefresh">
    <view
      class="event-card"
      wx:for="{{events}}"
      wx:key="name"
      data-name="{{item.name}}"
      bindtap="onEventTap"
      hover-class="event-card-hover"
    >
      <view class="event-info">
        <view class="event-name-line">
          <text class="event-name">{{item.name}}</text>
          <text wx:if="{{item.gradeLabel}}" style="display:inline-block;font-size:10px;font-weight:700;padding:1px 5px;border-radius:3px;color:#fff;background:{{item.badgeColor || '#999'}};margin-left:4px;vertical-align:middle;">{{item.gradeLabel}}</text>
        </view>
        <view class="event-meta">
          <text class="event-count">{{item.matchCount}} 场比赛</text>
          <text class="event-date">最近: {{item.latestDate}}</text>
        </view>
      </view>
      <text class="event-arrow">›</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && events.length === 0}}">
      <text>暂无赛事数据</text>
    </view>
  </scroll-view>
</view>
