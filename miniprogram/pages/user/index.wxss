/* miniprogram/pages/user/index.wxss */

.user-page {
  padding: 0;
  background-color: var(--bg-page);
  min-height: 100vh;
}

/* Header Section */
.header {
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-page) 100%);
  padding: 60rpx 40rpx;
  border-bottom: 1rpx solid var(--border-color);
}

/* Login Area */
.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  background-color: var(--bg-input);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
  border: 2rpx dashed var(--border-color);
}

.icon-user {
  width: 60rpx;
  height: 60rpx;
  opacity: 0.5;
}

.btn-login {
  background-color: var(--btn-primary-bg);
  color: var(--btn-primary-text);
  font-weight: bold;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  width: 300rpx;
  margin-bottom: 20rpx;
}

.login-tips {
  color: var(--text-muted);
  font-size: 24rpx;
}

/* User Info Display */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 50rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid var(--primary-color);
  margin-right: 30rpx;
  background-color: var(--bg-input);
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.level-badge {
  display: inline-block;
  background: linear-gradient(90deg, #FFC107, #FF9800);
  color: #000;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* Stats Row */
.stats-row {
  display: flex;
  justify-content: space-around;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: var(--shadow-sm);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Menu List */
.menu-list {
  padding: 40rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: var(--bg-card);
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.menu-item:active {
  background-color: var(--bg-hover);
}

.menu-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.arrow {
  color: var(--text-muted);
  font-size: 28rpx;
}

/* Menu Spacer */
.menu-spacer {
  height: 20rpx;
}

/* Footer */
.footer {
  padding: 40rpx;
  text-align: center;
}

.btn-logout {
  background-color: transparent;
  border: 1rpx solid var(--error-color);
  color: var(--error-color);
  font-size: 28rpx;
  padding: 16rpx 0;
  width: 100%;
  border-radius: 12rpx;
}

/* ========== 编辑资料提示 ========== */
.edit-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 6rpx;
}

/* ========== Modal / 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--modal-backdrop);
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  background: var(--modal-bg);
  border-radius: 20rpx;
  width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--modal-border);
  color: var(--text-primary);
}

.modal-body {
  padding: 20rpx 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid var(--modal-border);
}

.modal-footer .btn-primary,
.modal-footer .btn-secondary {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  text-align: center;
}

.btn-primary {
  background-color: var(--btn-primary-bg);
  color: var(--btn-primary-text);
  border: none;
}

.btn-secondary {
  background-color: var(--btn-secondary-bg);
  color: var(--btn-secondary-text);
  border: none;
}

/* ========== 编辑资料 ========== */
.edit-modal {
  width: 560rpx;
}

.edit-body {
  padding: 30rpx;
}

.edit-avatar-row,
.edit-input-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.edit-label {
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100rpx;
  flex-shrink: 0;
}

.avatar-btn {
  padding: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.edit-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
}

.edit-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ========== 竞猜记录 ========== */
.record-modal {
  width: 640rpx;
}

.record-list {
  max-height: 60vh;
  padding: 20rpx 30rpx;
}

.record-empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 28rpx;
  padding: 60rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.record-item:last-child {
  border-bottom: none;
}

.record-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-status.won {
  background-color: var(--success-color);
}

.record-status.lost {
  background-color: var(--error-color);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.record-player {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-detail {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  margin-left: 10rpx;
}

.record-loading {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* ====== 封神榜 ====== */
.ranking-modal {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.ranking-tab {
  display: flex;
  border-bottom: 2rpx solid var(--border-color);
  margin-bottom: 20rpx;
}

.ranking-tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.ranking-tab-item.ranking-tab-active {
  color: var(--text-primary);
  font-weight: 600;
}

.ranking-tab-item.ranking-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.ranking-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.ranking-empty {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}

.ranking-num {
  width: 50rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  flex-shrink: 0;
}

.ranking-num.ranking-top {
  color: #ff6b35;
  font-weight: 700;
}

.ranking-info {
  flex: 1;
  min-width: 0;
}

.ranking-name {
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ranking-stats {
  text-align: right;
  flex-shrink: 0;
}

.ranking-rate {
  font-size: 30rpx;
  font-weight: 700;
  color: #07c160;
  display: block;
}

.ranking-detail {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
}

.ranking-loading {
  text-align: center;
  padding: 20rpx 0;
  color: var(--text-muted);
  font-size: 24rpx;
}
