/* miniprogram/pages/matchDetail/matchDetail.wxss */

.match-detail-page {
  padding: 0 0 180rpx 0;
}

/* ====== 比赛头部 ====== */
.match-hero {
  background: linear-gradient(135deg, #1a1d2e 0%, #0f111a 100%);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.hero-event {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}
.hero-matchup {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
}
.hero-team {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.hero-logo-wrap {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.05);
}
.hero-logo {
  width: 100%;
  height: 100%;
}
.hero-team-name {
  font-size: 26rpx;
  font-weight: bold;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}
.hero-score-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 140rpx;
}
.hero-vs {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-muted);
}
.hero-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.hero-score {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.hero-score.flash .hero-score-num {
  animation: scorePop 0.5s ease-out;
}
.hero-score-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-inverse);
}
.hero-score-num.win {
  color: var(--success-color);
  text-shadow: 0 0 20rpx rgba(0,200,83,0.3);
}
.hero-score-colon {
  font-size: 40rpx;
  color: var(--text-muted);
}
.hero-status {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.05);
}
.hero-status.live {
  color: #FF3D00;
  background: rgba(255,61,0,0.1);
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.live-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FF3D00;
  animation: dotPulse 1.5s ease-in-out infinite;
}

/* ====== 通用区块 ====== */
.section {
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  padding: 20rpx 0 16rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 12rpx;
}

/* ====== 局分表 ====== */
.round-scores {
  background: var(--bg-card);
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid var(--border-color);
}
.round-header,
.round-row {
  display: flex;
  flex-direction: row;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
}
.round-header {
  background: var(--bg-input);
  font-weight: bold;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-color);
}
.round-row:not(:last-child) {
  border-bottom: 1rpx solid var(--border-light);
}
.round-cell.map { flex: 2; }
.round-cell.score { flex: 1; text-align: center; }
.round-cell.win-color { color: var(--success-color); font-weight: bold; }

/* ====== 选手数据表 ====== */
.team-stats-block {
  background: var(--bg-card);
  border-radius: 14rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  border: 1rpx solid var(--border-color);
}
.ts-team-name {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.ts-header,
.ts-row {
  display: flex;
  flex-direction: row;
  padding: 10rpx 0;
  font-size: 24rpx;
  align-items: center;
}
.ts-header {
  color: var(--text-muted);
  font-size: 22rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.ts-cell.name { flex: 2.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ts-cell.num { flex: 1; text-align: center; }
.ts-cell.rating { color: var(--accent-color); }

/* ====== 评论标签 ====== */
.player-tabs {
  white-space: nowrap;
  padding: 8rpx 0;
}
.player-tab {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: var(--bg-input);
  color: var(--text-secondary);
}
.player-tab.active {
  background: var(--accent-color);
  color: var(--text-inverse);
  font-weight: bold;
}
.tab-team {
  font-size: 20rpx;
  opacity: 0.7;
}

/* ====== 评论列表 ====== */
.comment-list {
  margin-bottom: 200rpx;
}
.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}
.comment-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
}
.comment-user {
  color: var(--text-secondary);
}
.comment-player {
  color: var(--accent-color);
  font-weight: bold;
}
.comment-team {
  color: var(--text-muted);
  font-size: 20rpx;
}
.comment-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: block;
}
.comment-time {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 6rpx;
}
.empty-state {
  text-align: center;
  color: var(--text-muted);
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* ====== 底部输入栏（三行紧凑布局） ====== */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 10rpx 16rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-color);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.pick-player-btn {
  width: 100%;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: var(--bg-input);
  color: var(--text-primary);
  border: none;
  text-align: left;
}
.comment-input {
  width: 100%;
  height: 70rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: var(--text-primary);
  caret-color: var(--accent-color);
  box-sizing: border-box;
}
.ph {
  color: var(--text-muted);
  font-size: 22rpx;
}
.char-count {
  text-align: right;
  font-size: 18rpx;
  color: var(--text-muted);
  margin-top: -4rpx;
  padding-right: 6rpx;
}
.send-btn {
  width: 100%;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: var(--accent-color);
  color: var(--text-inverse);
  border: none;
  text-align: center;
}
.send-btn.disabled {
  opacity: 0.4;
}

/* ====== 弹窗 ====== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: var(--modal-backdrop);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.modal-content {
  width: 100%;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  text-align: center;
  color: var(--text-primary);
}
.team-group {
  margin-bottom: 20rpx;
}
.group-title {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--accent-color);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}
.player-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
  background: var(--bg-input);
}
.player-row:active {
  background: var(--bg-hover);
}
.pr-name { font-size: 28rpx; font-weight: bold; }
.pr-pos { font-size: 22rpx; color: var(--text-muted); }
.modal-footer {
  margin-top: 20rpx;
  text-align: center;
}
.btn-cancel {
  width: 60%;
  background: var(--btn-secondary-bg) !important;
  color: var(--btn-secondary-text) !important;
  border: none !important;
  border-radius: 40rpx !important;
}

/* ====== 动画 ====== */
@keyframes scorePop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
