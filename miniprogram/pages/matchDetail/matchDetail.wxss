/* miniprogram/pages/matchDetail/matchDetail.wxss */

.match-detail-page {
  padding: 0 0 180rpx 0;  /* 底部留出输入栏空间 */
}

/* 比赛信息卡片 - 复用 match 页样式 */
.match-card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.card-header {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 16rpx;
}

.header-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

/* WS 实时指示绿点（详情页 Live 状态用） */
.ws-badge {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ws-badge.online .ws-dot-sm {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: var(--success-color);
  animation: wsLivePulse 1.5s ease-in-out infinite;
}

@keyframes wsLivePulse {
  0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 6rpx var(--success-color); }
  50% { opacity: 0.5; transform: scale(0.8); box-shadow: 0 0 2rpx var(--success-color); }
}

.header-left {
  flex: 1;
  min-width: 0;
}

.event-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: bold;
  text-transform: uppercase;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.1);
  color: var(--text-muted);
  font-weight: bold;
}

.status-badge.live {
  background-color: rgba(255, 61, 0, 0.1);
  color: #FF3D00;
  border: 1rpx solid rgba(255, 61, 0, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.match-content {
  position: relative;
}

.team {
  width: 30%;
}

.team-logo {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
  background-color: #000;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.team-name {
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.score-board {
  width: 40%;
}

.score-text {
  font-size: 56rpx;
  font-weight: 800;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  letter-spacing: 4rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.3s ease;
}

/* Live 比分脉冲 */
.score-text.score-live .winner {
  animation: detailScorePulse 2s ease-in-out infinite;
}

@keyframes detailScorePulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 比分变化闪动 */
.score-text.score-flash {
  animation: flashPop 0.5s ease-out;
}

@keyframes flashPop {
  0% { transform: scale(0.85); opacity: 0.5; }
  50% { transform: scale(1.15); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.winner {
  color: var(--success-color);
}

.divider {
  color: var(--text-muted);
  margin: 0 16rpx;
  font-size: 40rpx;
  transform: translateY(-4rpx);
}

.vs-text {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.match-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  background-color: rgba(255, 255, 255, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 选手筛选 tab */
.player-tabs {
  white-space: nowrap;
  padding: 0 20rpx 20rpx 20rpx;
  background-color: transparent;
}

.player-tab {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  background-color: var(--bg-input);
  border-radius: 24rpx;
  color: var(--text-secondary);
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.player-tab.active {
  background-color: var(--primary-color);
  color: #000;
  font-weight: bold;
  border-color: var(--primary-color);
}

/* 评论列表 */
.comment-list {
  padding: 0 20rpx;
}

.comment-item {
  display: flex;
  align-items: flex-start;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #000;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.player-tag {
  display: inline-flex;
  align-items: center;
  background-color: rgba(0, 229, 255, 0.1);
  border: 1rpx solid var(--primary-color);
  border-radius: 12rpx;
  padding: 2rpx 12rpx;
  font-size: 22rpx;
  color: var(--primary-color);
}

.player-name {
  font-weight: bold;
}

.player-team {
  opacity: 0.7;
  font-size: 20rpx;
}

.comment-content {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  word-break: break-word;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

.empty-state {
  text-align: center;
  color: var(--text-muted);
  padding: 80rpx 0;
  font-size: 26rpx;
}

/* 底部固定输入栏 */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--bg-card);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 12rpx 20rpx;
  z-index: 100;
}

.selected-player {
  display: flex;
  align-items: center;
  padding: 4rpx 0 12rpx 0;
  font-size: 24rpx;
}

.sp-label {
  color: var(--text-muted);
}

.sp-name {
  color: var(--primary-color);
  font-weight: bold;
  margin-right: 12rpx;
}

.sp-clear {
  color: var(--text-muted);
  font-size: 36rpx;
  line-height: 1;
  padding: 0 8rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-input {
  flex: 1;
  background-color: var(--bg-input);
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  min-height: 36rpx;
}

.ph {
  color: var(--text-muted);
}

.send-btn {
  font-size: 26rpx;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  background-color: var(--bg-input);
  color: var(--text-secondary);
  border: none;
  line-height: 1.4;
  margin: 0;
}

.send-btn::after {
  border: none;
}

.send-btn.primary {
  background-color: var(--primary-color);
  color: #000;
  font-weight: bold;
}

.send-btn.disabled {
  opacity: 0.5;
}

/* 选手选择 modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background-color: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
  color: var(--text-primary);
}

.team-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: bold;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 12rpx;
}

.player-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 12rpx;
  background-color: var(--bg-input);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.player-row:active {
  background-color: var(--bg-hover);
}

.pr-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.pr-position {
  font-size: 22rpx;
  color: var(--text-muted);
  background-color: rgba(255, 255, 255, 0.05);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.empty-team {
  text-align: center;
  padding: 16rpx 0;
  color: var(--text-muted);
  font-size: 24rpx;
}

.modal-footer {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.btn-cancel {
  background-color: var(--bg-input);
  color: var(--text-secondary);
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 60rpx;
  font-size: 28rpx;
  margin: 0;
}

.btn-cancel::after {
  border: none;
}