<view class="container home-page">
  <!-- 背景层 -->
  <image class="bg-image" src="/beijing.png" mode="aspectFill" />
  <view class="bg-fix-layer"></view>

  <!-- 头部欢迎 -->
  <view class="hero">
    <image class="hero-logo" src="/assets/icons/SS.png" mode="aspectFit" />
    <text class="hero-title">云雪CS助手</text>
    <text class="hero-desc">赛事查询 · 选手资料 · 趣味竞猜</text>
  </view>

  <!-- 上排三个 -->
  <view class="grid-row row-top">
    <view
      class="grid-item item-third"
      wx:for="{{topMenus}}"
      wx:key="id"
      data-item="{{item}}"
      catchtap="onTapMenu"
    >
      <text class="grid-title">{{item.title}}</text>
      <text class="grid-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 下排两个 -->
  <view class="grid-row row-bottom">
    <view
      class="grid-item item-half"
      wx:for="{{bottomMenus}}"
      wx:key="id"
      data-item="{{item}}"
      catchtap="onTapMenu"
    >
      <text class="grid-title">{{item.title}}</text>
      <text class="grid-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <text class="footer-text">为CS玩家提供一站式服务</text>
  </view>
</view>
