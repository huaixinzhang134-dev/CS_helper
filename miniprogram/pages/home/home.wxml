<view class="container home-page">
  <!-- 背景层 -->
  <image class="bg-image" src="/beijing.png" mode="aspectFill" />
  <view class="bg-fix-layer"></view>

  <!-- 头部欢迎 -->
  <view class="hero">
    <image class="hero-logo" src="/assets/icons/yunxue.png" mode="aspectFit" />
    <text class="hero-title">云雪CS助手</text>
    <text class="hero-desc">赛事查询 · 选手资料 · 趣味竞猜</text>
  </view>

  <!-- 上排三个 -->
  <view class="grid-row row-top">
    <view
      class="grid-item item-third"
      wx:for="{{topMenus}}"
      wx:key="id"
      data-item="{{item}}"
      catchtap="onTapMenu"
    >
      <text class="grid-title">{{item.title}}</text>
      <text class="grid-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 下排两个 -->
  <view class="grid-row row-bottom">
    <view
      class="grid-item item-half"
      wx:for="{{bottomMenus}}"
      wx:key="id"
      data-item="{{item}}"
      catchtap="onTapMenu"
    >
      <text class="grid-title">{{item.title}}</text>
      <text class="grid-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <text class="footer-text">为CS玩家提供一站式服务</text>
  </view>

  <!-- ====== 版本更新公告弹窗 ====== -->
  <view class="modal-mask" wx:if="{{showUpdateModal}}" bindtap="onUpdateMaskTap">
    <view class="update-modal" catchtap="">
      <view class="update-header">
        <text class="update-title">📢 版本更新公告</text>
      </view>
      <view class="update-body">
        <view class="update-inner">
          <text class="update-content">{{updateContent}}</text>
        </view>
      </view>
      <view class="update-footer">
        <button class="update-btn" bindtap="onCloseUpdate">我收到</button>
      </view>
    </view>
  </view>
</view>
