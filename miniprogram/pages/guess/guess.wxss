/* miniprogram/pages/guess/guess.wxss */

.guess-page {
  position: relative;
  background-color: #0F111A; /* Fallback */
  color: #fff;
  padding: 0;
  height: 100vh;
  overflow: hidden;
}

/* Background Image with 15% opacity - 强制 GPU 合成层减少闪烁 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.15;
  z-index: 0;
  pointer-events: none;
  /* 提升为独立合成层，避免随 input 重绘 */
  transform: translateZ(0);
  will-change: transform;
}

/* 额外隔离层：防止背景区域跟随输入光标闪烁重绘 */
.bg-fix-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
  background-color: transparent;
}

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background-color: #1E212B;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 40rpx;
  width: calc(100% - 80rpx);
  max-width: 600rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.5);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-body {
  margin-bottom: 40rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

/* Game Mode Selection */
.mode-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mode-btn {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  color: #fff;
  font-size: 30rpx;
  margin: 0;
  text-align: left;
}

.mode-btn::after {
  border: none;
}

.mode-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.mode-text {
  display: flex;
  flex-direction: column;
}

.mode-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: #888;
}

/* Friend PK Invite */
.invite-section {
  text-align: center;
}

.invite-text {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 30rpx;
  display: block;
}

.invite-tips {
  text-align: left;
  background-color: rgba(0, 229, 255, 0.1);
  padding: 20rpx;
  border-radius: 10rpx;
  border-left: 3rpx solid var(--primary-color);
}

.invite-tips text {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.invite-tips text:last-child {
  margin-bottom: 0;
}

/* Opponent Info */
.opponent-info {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  align-items: center;
  margin-top: 10rpx;
}

.opponent-name {
  font-size: 24rpx;
  color: var(--primary-color);
}

.opponent-score {
  font-size: 24rpx;
  color: var(--secondary-color);
}

/* PK Result */
.pk-result {
  margin-top: 20rpx;
  text-align: center;
}

.pk-result-text {
  font-size: 28rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
}

.pk-result-text.win {
  color: var(--success-color);
  background-color: rgba(0, 255, 127, 0.1);
}

.pk-result-text.lose {
  color: var(--danger-color);
  background-color: rgba(255, 69, 69, 0.1);
}

/* Header */
.header {
  position: relative;
  z-index: 2;
  text-align: center;
  padding-top: 40rpx;
  padding-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: #fff;
  font-style: italic;
}

.highlight {
  color: var(--primary-color);
  text-shadow: 0 0 10rpx rgba(0, 229, 255, 0.6);
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* Game Board - 提升为独立层减少重绘 */
.game-board {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  height: calc(100vh - 160rpx);
  transform: translateZ(0);
}

/* Legend */
.legend {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.legend-item {
  font-size: 32rpx;
}

.legend-item.green { color: var(--success-color); }
.legend-item.yellow { color: var(--secondary-color); }
.legend-item.grey { color: var(--text-muted); }

/* Search Section - 提升合成层减少重绘 */
.search-section {
  position: relative;
  margin-bottom: 20rpx;
  z-index: 10;
  will-change: transform;
  transform: translateZ(0);
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.search-input {
  flex: 1;
  color: #fff;
  margin-left: 20rpx;
  font-size: 28rpx;
}

.placeholder {
  color: #666;
}

.search-results {
  position: absolute;
  top: 90rpx;
  left: 0;
  right: 0;
  background-color: #2C2F3E;
  border-radius: 12rpx;
  max-height: 600rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  overflow: hidden;
}

.loading-more, .no-more {
  text-align: center;
  padding: 20rpx;
  color: #888;
  font-size: 24rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.result-item:last-child {
  border-bottom: none;
}

.player-avatar-sm {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #000;
}

.result-info {
  display: flex;
  flex-direction: column;
}

.player-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.player-team {
  color: var(--text-secondary);
  font-size: 22rpx;
}

.player-id {
  color: var(--text-secondary);
  font-size: 22rpx;
}

.result-id {
  color: var(--primary-color);
  font-size: 22rpx;
  margin-left: auto;
}

/* Game Result */
.game-result {
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
}

.result-box {
  background-color: rgba(0, 0, 0, 0.4);
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.result-text {
  font-size: 32rpx;
  font-weight: bold;
}

.result-text.won { color: var(--success-color); }
.result-text.lost { color: var(--error-color); }

.btn-restart {
  background-color: var(--primary-color);
  color: #000;
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

/* Data Table */
.table-header {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(0, 229, 255, 0.3);
  margin-bottom: 10rpx;
}

.th {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  font-weight: bold;
}

.guesses-list {
  flex: 1;
  overflow-y: auto;
}

.guess-row {
  display: flex;
  margin-bottom: 4rpx; /* Gap between rows */
  height: 80rpx;
}

.td {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background-color: rgba(255, 255, 255, 0.1);
  margin-right: 2rpx;
  position: relative;
}

.td:last-child {
  margin-right: 0;
}

/* Column Widths - Adjust to match reference */
.col-name { flex: 1.5; }
.col-team { flex: 1.5; }
.col-country { flex: 0.8; }
.col-age { flex: 1; }
.col-pos { flex: 1.2; }
.col-major { flex: 1.2; }

/* Status Colors */
.td.correct {
  background-color: var(--success-color);
  color: #fff;
}

.td.close {
  background-color: var(--secondary-color);
  color: #000;
}

.td.incorrect {
  background-color: rgba(255, 255, 255, 0.15); /* Greyish */
  color: var(--text-secondary);
}

.arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
  font-weight: bold;
}

/* Attempts Indicator */
.attempts-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.attempt-box {
  width: 60rpx;
  height: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
}

.attempt-box.used {
  background-color: var(--error-color);
  border-color: var(--error-color);
}

.attempt-box.success {
  background-color: var(--success-color);
  border-color: var(--success-color);
  /* Optional: Add checkmark with pseudo-element if needed */
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal-content {
  width: 600rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.modal-body {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.modal-footer {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #000;
  border: none;
  font-size: 28rpx;
  flex: 1;
}

.btn-secondary {
  background-color: transparent;
  color: var(--text-muted);
  border: 1rpx solid var(--text-muted);
  font-size: 28rpx;
  flex: 1;
}

/* Give Up Button - Header Position (Personal Mode) */
.btn-give-up-header {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  padding: 16rpx 40rpx;
  background-color: rgba(255, 69, 69, 0.9);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 30rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 69, 69, 0.4);
}

.btn-give-up-header::after {
  border: none;
}

.btn-give-up-header:active {
  background-color: rgba(255, 69, 69, 1);
  transform: translateX(-50%) scale(0.95);
}

/* Give Up Button */
.btn-give-up {
  width: 100%;
  padding: 24rpx 0;
  margin-top: 20rpx;
  background-color: rgba(255, 69, 69, 0.8);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.btn-give-up::after {
  border: none;
}

.btn-give-up:active {
  background-color: rgba(255, 69, 69, 1);
  transform: scale(0.98);
}

/* Result Modal - 目标选手信息 */
.result-target-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.result-target-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary-color);
  flex-shrink: 0;
  background-color: #000;
}

.result-target-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  flex: 1;
}

.result-target-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.result-target-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.result-target-team {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ====== PK 对战状态栏 ====== */
.pk-status {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 40rpx;
  margin: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.08), rgba(255, 165, 0, 0.08));
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.15);
  position: relative;
  z-index: 2;
}
.pk-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.pk-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.1);
}
.pk-me .pk-avatar {
  border-color: var(--primary-color);
}
.pk-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pk-attempts {
  font-size: 20rpx;
  color: var(--text-muted);
}
.pk-vs {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--secondary-color);
}