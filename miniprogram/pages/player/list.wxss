/* miniprogram/pages/player/list.wxss */

.player-list-page {
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
  padding-left: 10rpx;
}

.subtitle {
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* Search Box */
.search-box {
  display: flex;
  align-items: center;
  background-color: var(--bg-input);
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid var(--border-color);
}

.search-input {
  flex: 1;
  color: var(--text-primary);
  margin-left: 20rpx;
  font-size: 28rpx;
}

.placeholder {
  color: var(--text-muted);
}

/* List Container */
.list-container {
  height: calc(100vh - 220rpx);
}

.player-list {
  display: flex;
  flex-wrap: wrap;
}

.list-item {
  width: 33.33%;
  height: 80rpx; /* 40px */
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--border-color);
  transition: background-color 0.2s;
}

.list-item:active {
  background-color: var(--bg-hover);
}

.player-name {
  font-size: 26rpx;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Loading & No More Indicators */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: var(--text-secondary);
  font-size: 24rpx;
  width: 100%;
}

.empty-state {
  text-align: center;
  color: var(--text-muted);
  margin-top: 100rpx;
}
