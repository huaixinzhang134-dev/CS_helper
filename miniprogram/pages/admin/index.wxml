<view class="container admin-page">
  <!-- ====== Tab 导航 ====== -->
  <view class="admin-tabs">
    <view
      class="admin-tab {{activeTab === tab.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-tab="{{tab.key}}"
      catchtap="switchTab"
    >{{tab.label}}</view>
  </view>

  <!-- ==================== 用户管理 ==================== -->
  <view wx:if="{{activeTab === 'users'}}">
    <scroll-view scroll-y class="admin-list" bindscrolltolower="onUsersScrollToLower">
      <view class="admin-card" wx:for="{{users}}" wx:key="openid">
        <view class="card-header">
          <text class="card-title">{{item.nickname || '匿名'}}</text>
          <text class="card-subtitle">🪙 {{item.coins}}</text>
        </view>
        <view class="card-body">
          <text>胜场: {{item.winCount}} | 总局: {{item.totalGames}} | 胜率: {{item.winRate}}%</text>
          <text class="card-meta">openid: {{item.openid}}</text>
        </view>
        <view class="card-actions">
          <button size="mini" bindtap="onEditUser" data-user="{{item}}">编辑</button>
          <button size="mini" type="warn" bindtap="onDeleteUser" data-openid="{{item.openid}}">删除</button>
        </view>
      </view>
      <view class="loading-text" wx:if="{{usersLoading}}">加载中...</view>
    </scroll-view>

    <!-- 编辑用户弹窗 -->
    <view class="modal" wx:if="{{editUserModal}}">
      <view class="modal-content">
        <view class="h2">编辑用户</view>
        <text class="modal-meta">OpenID: {{editUserOpenid}}</text>
        <input class="input" placeholder="昵称" value="{{editUserNickname}}" data-field="Nickname" bindinput="onEditUserFieldChange"/>
        <input class="input" type="number" placeholder="代币数量" value="{{editUserCoins}}" data-field="Coins" bindinput="onEditUserFieldChange"/>
        <button type="primary" bindtap="onSaveUser">保存</button>
        <button bindtap="onCloseUserModal">取消</button>
      </view>
    </view>
  </view>

  <!-- ==================== 选手管理 ==================== -->
  <view wx:if="{{activeTab === 'players'}}">
    <button class="btn-add" type="primary" bindtap="onAddPlayer">+ 添加选手</button>
    <scroll-view scroll-y class="admin-list">
      <view class="admin-card" wx:for="{{players}}" wx:key="_id">
        <view class="card-header">
          <text class="card-title">{{item.name}}</text>
          <text class="card-subtitle">{{item.team || '无战队'}}</text>
        </view>
        <view class="card-body">
          <text>{{item.country}} · {{item.position}} · {{item.age}}岁</text>
        </view>
        <view class="card-actions">
          <button size="mini" bindtap="onEditPlayer" data-item="{{item}}">编辑</button>
          <button size="mini" type="warn" bindtap="onDeletePlayer" data-id="{{item._id}}">删除</button>
        </view>
      </view>
    </scroll-view>

    <!-- 选手编辑弹窗 -->
    <view class="modal" wx:if="{{showPlayerModal}}">
      <view class="modal-content">
        <view class="h2">{{isEditingPlayer ? '编辑' : '添加'}}选手</view>
        <input class="input" placeholder="游戏ID" value="{{playerForm.name}}" data-field="name" bindinput="onPlayerFieldChange"/>
        <input class="input" placeholder="真名" value="{{playerForm.realName}}" data-field="realName" bindinput="onPlayerFieldChange"/>
        <input class="input" placeholder="战队" value="{{playerForm.team}}" data-field="team" bindinput="onPlayerFieldChange"/>
        <input class="input" placeholder="国家" value="{{playerForm.country}}" data-field="country" bindinput="onPlayerFieldChange"/>
        <input class="input" type="number" placeholder="年龄" value="{{playerForm.age}}" data-field="age" bindinput="onPlayerFieldChange"/>
        <input class="input" wx:if="{{!isEditingPlayer}}" placeholder="playerId(数字)" value="{{playerForm.playerId}}" data-field="playerId" bindinput="onPlayerFieldChange"/>
        <picker bindchange="onPositionChange" value="{{playerForm.position}}" range="{{positions}}">
          <view class="picker">位置: {{playerForm.position}}</view>
        </picker>
        <button type="primary" bindtap="onSavePlayer">保存</button>
        <button bindtap="onCloseModal">取消</button>
      </view>
    </view>
  </view>

  <!-- ==================== 赛事管理 ==================== -->
  <view wx:if="{{activeTab === 'matches'}}">
    <button class="btn-add" type="primary" bindtap="onAddMatch">+ 添加赛事</button>
    <scroll-view scroll-y class="admin-list">
      <view class="admin-card" wx:for="{{matches}}" wx:key="_id">
        <view class="card-header">
          <text class="card-title">{{item.event}}</text>
          <text class="card-subtitle status-{{item.status}}">{{item.status}}</text>
        </view>
        <view class="card-body">
          <text>{{item.teamA?.name || '?'}} vs {{item.teamB?.name || '?'}}</text>
        </view>
        <view class="card-actions">
          <button size="mini" bindtap="onEditMatch" data-item="{{item}}">编辑</button>
          <button size="mini" type="warn" bindtap="onDeleteMatch" data-id="{{item._id}}">删除</button>
        </view>
      </view>
    </scroll-view>

    <!-- 赛事编辑弹窗 -->
    <view class="modal" wx:if="{{showMatchModal}}">
      <view class="modal-content">
        <view class="h2">{{isEditingMatch ? '编辑' : '添加'}}赛事</view>
        <input class="input" placeholder="赛事名称" value="{{matchForm.event}}" data-field="event" bindinput="onMatchFieldChange"/>
        <picker bindchange="onStatusChange" range="{{statuses}}">
          <view class="picker">状态: {{matchForm.status}}</view>
        </picker>
        <input class="input" placeholder="队伍A名称" value="{{matchForm.teamA.name}}" data-field="teamA.name" bindinput="onMatchFieldChange"/>
        <input class="input" type="number" placeholder="队伍A分数" value="{{matchForm.teamA.score}}" data-field="teamA.score" bindinput="onMatchFieldChange"/>
        <input class="input" placeholder="队伍B名称" value="{{matchForm.teamB.name}}" data-field="teamB.name" bindinput="onMatchFieldChange"/>
        <input class="input" type="number" placeholder="队伍B分数" value="{{matchForm.teamB.score}}" data-field="teamB.score" bindinput="onMatchFieldChange"/>
        <button type="primary" bindtap="onSaveMatch">保存</button>
        <button bindtap="onCloseModal">取消</button>
      </view>
    </view>
  </view>

  <!-- ==================== 评论审核 ==================== -->
  <view wx:if="{{activeTab === 'comments'}}">
    <scroll-view scroll-y class="admin-list" bindscrolltolower="onCommentsScrollToLower">
      <view class="admin-card" wx:for="{{pendingComments}}" wx:key="_id">
        <view class="card-header">
          <text class="card-title">{{item.userName}}</text>
          <text class="card-subtitle">{{item.playerGameId}}</text>
        </view>
        <view class="card-body">
          <text class="comment-content">{{item.content}}</text>
          <text class="card-meta">{{item.createdAt}}</text>
        </view>
        <view class="card-actions">
          <button size="mini" type="primary" bindtap="onReviewComment" data-id="{{item._id}}" data-status="approved">通过</button>
          <button size="mini" type="warn" bindtap="onReviewComment" data-id="{{item._id}}" data-status="rejected">驳回</button>
        </view>
      </view>
      <view class="empty-text" wx:if="{{pendingComments.length === 0 && !commentsLoading}}">暂无待审核评论</view>
      <view class="loading-text" wx:if="{{commentsLoading}}">加载中...</view>
    </scroll-view>
  </view>

  <!-- ==================== 投票管理 ==================== -->
  <view wx:if="{{activeTab === 'votes'}}">
    <view class="h2">年度 Top30 设定（{{voteYear}}）</view>
    <scroll-view scroll-y class="admin-list">
      <view class="admin-card" wx:for="{{30}}" wx:key="*this" wx:for-index="idx">
        <view class="card-header">
          <text class="card-title">Top{{idx + 1}}</text>
          <text class="card-subtitle" wx:if="{{voteWinners.find(w => w.rank === idx + 1)}}">
            {{voteWinners.find(w => w.rank === idx + 1).playerName}}
          </text>
        </view>
        <view class="card-actions">
          <button size="mini" bindtap="onVoteSetWinner" data-slot="{{idx + 1}}">
            {{voteWinners.find(w => w.rank === idx + 1) ? '更改' : '设置'}}
          </button>
          <button size="mini" type="warn" wx:if="{{voteWinners.find(w => w.rank === idx + 1)}}" bindtap="onVoteRemoveWinner" data-slot="{{idx + 1}}">移除</button>
        </view>
      </view>
    </scroll-view>
    <button class="btn-add" type="primary" bindtap="onSaveVoteWinners">保存 Top30</button>

    <view class="section-gap"></view>
    <view class="h2">核对结果 / 发奖</view>
    <view class="row">
      <text>猜对阈值:</text>
      <input class="input inline-input" type="number" value="{{checkThreshold}}" bindinput="onThresholdChange"/>
    </view>
    <view class="btn-group">
      <button bindtap="onCheckVoteResults">核对投票结果</button>
      <button type="warn" bindtap="onAwardVotes">发放代币奖励</button>
    </view>
    <view wx:if="{{awardResult}}">
      <text class="result-text">已向 {{awardResult.awardedUsers}} 人发放 {{awardResult.totalCoinsAwarded}} 代币</text>
    </view>

    <!-- 投票搜索弹窗 -->
    <view class="modal" wx:if="{{showVoteSearch}}">
      <view class="modal-content">
        <view class="h2">搜索选手 - Top{{voteSlot}}</view>
        <input class="input" placeholder="输入选手名称" value="{{voteSearchQuery}}" bindinput="onVoteSearchInput"/>
        <scroll-view scroll-y class="search-list">
          <view class="search-item" wx:for="{{voteSearchResults}}" wx:key="_id" data-player="{{item}}" catchtap="onVoteSelectPlayer">
            <text>{{item.name}}</text>
            <text class="card-meta">{{item.team}}</text>
          </view>
        </scroll-view>
        <button bindtap="onCloseSearch">取消</button>
      </view>
    </view>
  </view>
</view>
