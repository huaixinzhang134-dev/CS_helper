/* miniprogram/pages/admin/index.wxss */
.container {
  padding: 20rpx;
}

.card {
  margin-bottom: 40rpx;
  padding: 20rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  background-color: var(--bg-card);
}

.list-container {
  margin-top: 20rpx;
  max-height: 400rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
  color: var(--text-primary);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: var(--modal-backdrop);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal-content {
  background-color: var(--modal-bg);
  padding: 40rpx;
  border-radius: 16rpx;
  width: 80%;
  color: var(--text-primary);
}

.input {
  border: 1rpx solid var(--border-input);
  padding: 10rpx;
  margin-bottom: 20rpx;
  width: auto;
  background-color: var(--bg-input);
  color: var(--text-primary);
  border-radius: 8rpx;
}

.picker {
  border: 1rpx solid var(--border-input);
  padding: 10rpx;
  margin-bottom: 20rpx;
  background-color: var(--bg-input);
  color: var(--text-primary);
  border-radius: 8rpx;
}

.info {
  margin: 10rpx 0;
  color: var(--text-secondary);
}

.progress {
  margin: 20rpx 0;
}

.progress text {
  display: block;
  text-align: center;
  margin-top: 10rpx;
  color: var(--text-secondary);
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.btn-group button {
  margin-bottom: 10rpx;
}
