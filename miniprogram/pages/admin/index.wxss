.admin-page {
  padding: 20rpx;
}

/* ====== Tabs ====== */
.admin-tabs {
  display: flex;
  background: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid var(--border-color);
}

.admin-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  cursor: pointer;
}

.admin-tab.active {
  background: var(--primary-color);
  color: #fff;
  font-weight: 600;
}

/* ====== Buttons ====== */
.btn-add {
  margin-bottom: 20rpx;
  width: 100%;
}

/* ====== Card List ====== */
.admin-list {
  max-height: 70vh;
}

.admin-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-meta {
  font-size: 20rpx;
  color: var(--text-muted);
  word-break: break-all;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.comment-content {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.4;
}

/* ====== Modal ====== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--modal-backdrop);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal-content {
  background: var(--modal-bg);
  padding: 40rpx;
  border-radius: 16rpx;
  width: 80%;
  max-height: 80vh;
  overflow-y: auto;
  color: var(--text-primary);
}

.h2 {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.input {
  border: 1rpx solid var(--border-input);
  padding: 16rpx;
  margin-bottom: 16rpx;
  width: auto;
  background: var(--bg-input);
  color: var(--text-primary);
  border-radius: 8rpx;
  font-size: 26rpx;
}

.inline-input {
  width: 120rpx;
  display: inline-block;
  margin-left: 12rpx;
}

.picker {
  border: 1rpx solid var(--border-input);
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.modal-meta {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 16rpx;
  word-break: break-all;
}

/* ====== Vote section ====== */
.section-gap {
  height: 40rpx;
}

.row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.result-text {
  font-size: 26rpx;
  color: var(--success-color);
  display: block;
  padding: 16rpx;
  background: var(--bg-card);
  border-radius: 8rpx;
}

/* ====== Search list in modal ====== */
.search-list {
  max-height: 300rpx;
  margin-bottom: 16rpx;
}

.search-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  cursor: pointer;
}

.search-item:active {
  opacity: 0.7;
}

/* ====== Slot Toggle Grid ====== */
.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.slot-toggle {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(20% - 10rpx);
  padding: 12rpx 0;
  border-radius: 10rpx;
  border: 1rpx solid var(--border-color);
  cursor: pointer;
}

.slot-toggle.on {
  background: var(--bg-card);
}

.slot-toggle.off {
  background: #3d1a1a;
  border-color: #8b0000;
  opacity: 0.7;
}

.slot-toggle-label {
  font-size: 22rpx;
  color: var(--text-primary);
}

.slot-toggle-status {
  font-size: 18rpx;
  margin-top: 4rpx;
}

.slot-toggle.on .slot-toggle-status {
  color: #4CAF50;
}

.slot-toggle.off .slot-toggle-status {
  color: #ff5252;
}

/* ====== Login Page ====== */
.login-page {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 70vh;
}

.login-box {
  width: 80%;
  max-width: 500rpx;
  padding: 60rpx 40rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  border: 1rpx solid var(--border-color);
}

.login-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.login-error {
  display: block;
  color: var(--error-color);
  font-size: 24rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

/* ====== Admin Topbar ====== */
.admin-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
}

.admin-username {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ====== Common ====== */
.loading-text,
.empty-text {
  text-align: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}
