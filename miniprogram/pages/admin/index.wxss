/* 管理后台迁移提示 */
.admin-page {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 70vh;
  padding: 40rpx;
}

.redirect-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.redirect-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.redirect-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.redirect-url {
  font-size: 26rpx;
  color: var(--primary-color);
  text-decoration: underline;
  word-break: break-all;
}
