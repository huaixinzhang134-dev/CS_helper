/* miniprogram/pages/match/match.wxss */

.match-page {
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
  padding-left: 10rpx;
}

.header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.subtitle-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.subtitle {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.match-list {
  height: calc(100vh - 220rpx);
}

.match-card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: transform 0.2s;
}

.match-card-hover {
  background-color: var(--bg-hover);
  transform: scale(0.99);
  transition: all 0.1s;
}

.card-header {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 16rpx;
}

.event-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: bold;
  text-transform: uppercase;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.1);
  color: var(--text-muted);
  font-weight: bold;
}

.status-badge.live {
  background-color: rgba(255, 61, 0, 0.1);
  color: #FF3D00;
  border: 1rpx solid rgba(255, 61, 0, 0.3);
  animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.match-content {
  position: relative;
}

.team {
  width: 30%;
}

.team-logo-wrap {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border-radius: 50%;
  background-color: #000;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}
.team-logo {
  width: 100%;
  height: 100%;
}

.team-name {
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.score-board {
  width: 40%;
}

.score-text {
  font-size: 56rpx;
  font-weight: 800;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  letter-spacing: 4rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Live 比分脉冲 + 荧光效果 */
.score-text.score-live .winner {
  color: var(--success-color);
  text-shadow: 0 0 10rpx rgba(0, 200, 83, 0.3);
  animation: scorePop 2s ease-in-out infinite;
}

@keyframes scorePop {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.winner {
  color: var(--success-color);
  text-shadow: 0 0 10rpx rgba(0, 200, 83, 0.3);
}

.divider {
  color: var(--text-muted);
  margin: 0 16rpx;
  font-size: 40rpx;
  transform: translateY(-4rpx);
}

.vs-text {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.match-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  background-color: rgba(255, 255, 255, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.finished-time {
  margin-top: 8rpx;
  font-size: 18rpx;
  opacity: 0.7;
}

.empty-state {
  text-align: center;
  color: var(--text-muted);
  margin-top: 100rpx;
  font-size: 28rpx;
}

/* ==================== 实时指示器 ==================== */

/* WS 连接状态（右上角） */
.ws-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  background-color: rgba(255, 255, 255, 0.05);
}

.ws-status.connected {
  color: var(--success-color);
  background-color: rgba(0, 200, 83, 0.08);
}

.ws-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: currentColor;
}

.ws-status.connected .ws-dot {
  animation: dotPulse 2s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.7); }
}

/* Live 直播场次徽标 */
.live-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #FF3D00;
  background-color: rgba(255, 61, 0, 0.1);
  border: 1rpx solid rgba(255, 61, 0, 0.25);
}

.live-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #FF3D00;
  animation: dotPulse 1.5s ease-in-out infinite;
}