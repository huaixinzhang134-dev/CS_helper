<view class="container pick-page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">{{year}} 年度 Top30 猜测</text>
    <text class="page-desc">每位 top 独立提交，每位置最多 3 次覆盖式提交</text>
  </view>

  <!-- 进度 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{filledCount / 30 * 100}}%"></view>
  </view>
  <text class="progress-text">{{filledCount}} / 30 已选</text>

  <!-- 猜测表单 -->
  <scroll-view scroll-y class="pick-form" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view
      class="slot-item {{item.playerName ? 'filled' : ''}} {{!item.canSubmit ? 'disabled' : ''}}"
      wx:for="{{slots}}"
      wx:key="slot"
      data-slot="{{item.slot}}"
      catchtap="onSlotTap"
    >
      <text class="slot-label">Top{{item.slot}}</text>
      <view class="slot-value">
        <text class="slot-player" wx:if="{{item.playerName}}">{{item.playerName}}</text>
        <text class="slot-placeholder" wx:else>
          {{item.canSubmit ? '点击选择选手' : '提交已关闭'}}
        </text>
      </view>
      <view class="slot-meta">
        <text class="slot-count" wx:if="{{item.submissionNo > 0}}">{{item.submissionNo}}/{{item.maxSubmissions}}</text>
      </view>
      <view class="slot-clear" wx:if="{{item.playerName && item.canSubmit}}" data-slot="{{item.slot}}" catchtap="onClearSlot">✕</view>
    </view>
  </scroll-view>

  <!-- ====== 搜索弹出层（点击蒙层不关闭） ====== -->
  <view class="modal-mask" wx:if="{{activeSlot > 0}}">
    <view class="search-panel" catchtap="">
      <view class="search-header">
        <text class="search-title">选择 Top{{activeSlot}}</text>
        <text class="search-close" catchtap="onCloseSearch">✕</text>
      </view>
      <view class="slot-info">当前提交: 第 {{slots[activeSlot - 1].submissionNo + 1}} / {{slots[activeSlot - 1].maxSubmissions}} 次</view>

      <view class="search-input-wrap">
        <icon type="search" size="16" color="#aaa" />
        <input class="search-input" placeholder="输入选手名称搜索" value="{{searchQuery}}" bindinput="onSearchInput" focus="{{activeSlot > 0}}" />
      </view>

      <scroll-view scroll-y class="search-results" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view
          class="search-item {{selectedPlayer && selectedPlayer.playerId === item.playerId ? 'active' : ''}}"
          wx:for="{{searchResults}}"
          wx:key="_id"
          data-player-id="{{item.playerId}}"
          catchtap="onSelectPlayer"
        >
          <text class="search-player-name">{{item.name}}</text>
          <text class="search-player-team">{{item.team || '无战队'}}</text>
        </view>
        <view class="search-empty" wx:if="{{searchQuery && searchResults.length === 0 && !searchLoading}}">
          <text>未找到匹配选手</text>
        </view>
      </scroll-view>

      <!-- 已选择的选手 + 提交按钮 -->
      <view class="submit-bar" wx:if="{{selectedPlayer}}">
        <text class="selected-hint">已选: {{selectedPlayer.name}}</text>
        <button class="btn-submit" bindtap="onSubmitSlot" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '提交'}}
        </button>
      </view>
    </view>
  </view>
</view>
