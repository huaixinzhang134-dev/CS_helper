.vote-page {
  padding: 30rpx;
  min-height: 100vh;
}

/* ====== Header ====== */
.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}

.page-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

/* ====== Progress ====== */
.progress-bar {
  height: 12rpx;
  background: var(--bg-input);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  text-align: right;
  margin-bottom: 24rpx;
}

/* ====== Vote Form ====== */
.vote-form {
  max-height: 70vh;
}

.slot-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  cursor: pointer;
}

.slot-item:active {
  opacity: 0.8;
}

.slot-item.filled {
  border-color: var(--primary-color);
  background: var(--bg-hover);
}

.slot-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-color);
  width: 90rpx;
  flex-shrink: 0;
}

.slot-value {
  flex: 1;
  min-width: 0;
}

.slot-player {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.slot-placeholder {
  font-size: 26rpx;
  color: var(--text-muted);
}

.slot-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--error-color);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 禁用态（提交已关闭） */
.slot-item.disabled {
  opacity: 0.5;
}

.slot-item.disabled .slot-placeholder {
  color: var(--error-color);
}

/* 提交次数 */
.slot-meta {
  flex-shrink: 0;
  margin-left: 8rpx;
}

.slot-count {
  font-size: 22rpx;
  color: var(--text-muted);
  background: var(--bg-input);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

/* 搜索时显示当前提交次数信息 */
.slot-info {
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
  margin-bottom: 16rpx;
  padding: 8rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
}

/* ====== Submit ====== */
.submit-area {
  padding: 30rpx 0 60rpx;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 16rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* ====== Search Modal ====== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--modal-backdrop);
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.search-panel {
  background: var(--modal-bg);
  width: 100%;
  max-height: 70vh;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

.search-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.search-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-results {
  max-height: 50vh;
}

.search-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  cursor: pointer;
}

.search-item:active {
  opacity: 0.7;
}

.search-player-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.search-player-team {
  font-size: 24rpx;
  color: var(--text-muted);
}

.search-empty {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}
