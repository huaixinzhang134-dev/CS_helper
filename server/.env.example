# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=201005
DB_NAME=cs_match_pro

# 服务端口
PORT=3000

# 爬虫同步鉴权 Token（两端需保持一致）
# 爬虫服务通过 Authorization: Bearer <SYNC_TOKEN> 调用 /api/matches/sync
# 建议改一个随机字符串，不要用默认值
SYNC_TOKEN=cs-match-sync-token

# 微信小程序登录（从微信公众平台 → 开发管理 → 开发设置获取）
# WX_APPID=wxb08417e28e434e25
# WX_SECRET=你的 AppSecret
